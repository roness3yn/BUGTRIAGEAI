        "             min_df = 2 #Ignores words that only appear once)\n",
        "         ),\n",
        "         \"text\"\n",
        "        ),\n",
        "\n",
        "        (\n",
        "            \"categorical\",\n",
        "            #Encode features\n",
        "            OneHotEncoder(handle_unknown = \"ignore\"),\n",
        "            [\n",
        "                \"text\",\n",
        "                \"bug_domain\",\n",
        "                \"bug_category\",\n",
        "                \"environment\",\n",
