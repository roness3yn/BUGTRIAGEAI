      "cell_type": "code",
      "source": [
        "#Create processing pipeline\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers = [\n",
        "        (\n",
        "          \"text\",\n",
        "         TfidfVectorizer(\n",
        "             stop_words = 'english', #Remove common words\n",
